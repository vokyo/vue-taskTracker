{
  "name": "task-tracker-vue",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "npm run reset-data && concurrently -k -n API,APP -c green,blue \"npm run server\" \"npm run dev\"",
    "build": "vite build",
    "preview": "vite preview",
    "reset-data": "node scripts/reset-data.mjs",
    "server": "json-server --watch src/tasks.json --port 8000",
    "test": "vitest run"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "pinia": "^3.0.4",
    "primeicons": "^7.0.0",
    "uuid": "^13.0.0",
    "vue": "^3.4.29",
    "vue-router": "^4.4.0",
    "vue-spinner": "^1.0.4",
    "vue-toastification": "^2.0.0-rc.5",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.5",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.1.2",
    "jsdom": "^25.0.1",
    "json-server": "^1.0.0-beta.1",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "vite": "^5.3.1",
    "vitest": "^2.1.8"
  }
}
